# FACEMETRICS backend environment

# Runtime
APP_ENV=dev
LOG_LEVEL=INFO

# Database
# dev: SQLite relative to repo root
DATABASE_URL=sqlite+aiosqlite:///./data/facemetrics.db
# prod example:
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/facemetrics

# Anthropic Claude
ANTHROPIC_API_KEY=
CLAUDE_MODEL_VISION=claude-opus-4-6
CLAUDE_MODEL_TEXT=claude-sonnet-4-6

# Scheduler (KST)
SCHEDULER_TIMEZONE=Asia/Seoul
CRAWL_HOUR=8
ANALYZE_HOUR=10
ANALYZE_MINUTE=30
PUBLISH_HOUR=11

# CORS
FRONTEND_ORIGIN=http://localhost:3000
