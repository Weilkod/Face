# FACEMETRICS backend environment

# Runtime
APP_ENV=dev
LOG_LEVEL=INFO

# Database
# dev: SQLite relative to repo root
DATABASE_URL=sqlite+aiosqlite:///./data/facemetrics.db
# prod example:
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/facemetrics

# Anthropic Claude
ANTHROPIC_API_KEY=
CLAUDE_MODEL_VISION=claude-opus-4-6
CLAUDE_MODEL_TEXT=claude-sonnet-4-6

# Scheduler (KST)
# SCHEDULER_ENABLED: default true. Multi-replica deploy (Railway/Fly replicas >= 2)
# 에서는 한 워커만 true 로 두고 나머지는 false 로 설정해 크롤/분석/퍼블리시 잡
# 중복 실행 + Claude 토큰 2배 소모를 방지한다. 단일 worker 인 docker-compose/
# 로컬 dev 에서는 건드리지 않아도 됨.
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=Asia/Seoul
CRAWL_HOUR=8
ANALYZE_HOUR=10
ANALYZE_MINUTE=30
PUBLISH_HOUR=11

# CORS
FRONTEND_ORIGIN=http://localhost:3000
